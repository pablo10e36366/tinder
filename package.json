{
  "name": "tinder",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\" && nest build monolith",
    "build:gateway": "nest build api-gateway",
    "build:auth-service": "nest build auth-service",
    "build:users-service": "nest build users-service && node scripts/copy-prisma-generated.cjs users-service",
    "build:subscriptions-service": "nest build subscriptions-service",
    "build:interactions-service": "nest build interactions-service && node scripts/copy-prisma-generated.cjs interactions-service",
    "build:matches-service": "nest build matches-service && node scripts/copy-prisma-generated.cjs matches-service",
    "build:messages-service": "nest build messages-service && node scripts/copy-prisma-generated.cjs messages-service",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start monolith",
    "start:dev": "nest start monolith --watch",
    "start:debug": "nest start monolith --debug --watch",
    "start:prod": "node dist/main.js",
    "start:gateway": "nest start api-gateway",
    "start:gateway:dev": "nest start api-gateway --watch",
    "start:auth-service": "nest start auth-service",
    "start:auth-service:dev": "nest start auth-service --watch",
    "start:users-service": "npm run build:users-service && node dist/apps/users-service/apps/users-service/src/main.js",
    "start:users-service:dev": "nest start users-service --watch",
    "start:subscriptions-service": "nest start subscriptions-service",
    "start:subscriptions-service:dev": "nest start subscriptions-service --watch",
    "start:interactions-service": "npm run build:interactions-service && node dist/apps/interactions-service/apps/interactions-service/src/main.js",
    "start:interactions-service:dev": "nest start interactions-service --watch",
    "start:matches-service": "npm run build:matches-service && node dist/apps/matches-service/apps/matches-service/src/main.js",
    "start:matches-service:dev": "nest start matches-service --watch",
    "start:messages-service": "npm run build:messages-service && node dist/apps/messages-service/apps/messages-service/src/main.js",
    "start:messages-service:dev": "nest start messages-service --watch",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "prisma:generate": "prisma generate --config prisma.config.ts",
    "prisma:generate:auth-service": "prisma generate --config apps/auth-service/prisma/prisma.config.ts",
    "prisma:generate:users-service": "prisma generate --config apps/users-service/prisma/prisma.config.ts",
    "prisma:generate:subscriptions-service": "prisma generate --config apps/subscriptions-service/prisma/prisma.config.ts",
    "prisma:generate:interactions-service": "prisma generate --config apps/interactions-service/prisma/prisma.config.ts",
    "prisma:generate:matches-service": "prisma generate --config apps/matches-service/prisma/prisma.config.ts",
    "prisma:generate:messages-service": "prisma generate --config apps/messages-service/prisma/prisma.config.ts",
    "prisma:generate:services": "npm run prisma:generate:auth-service && npm run prisma:generate:users-service && npm run prisma:generate:subscriptions-service && npm run prisma:generate:interactions-service && npm run prisma:generate:matches-service && npm run prisma:generate:messages-service",
    "prisma:validate": "prisma validate --config prisma.config.ts",
    "prisma:validate:auth-service": "prisma validate --config apps/auth-service/prisma/prisma.config.ts",
    "prisma:validate:users-service": "prisma validate --config apps/users-service/prisma/prisma.config.ts",
    "prisma:validate:subscriptions-service": "prisma validate --config apps/subscriptions-service/prisma/prisma.config.ts",
    "prisma:validate:interactions-service": "prisma validate --config apps/interactions-service/prisma/prisma.config.ts",
    "prisma:validate:matches-service": "prisma validate --config apps/matches-service/prisma/prisma.config.ts",
    "prisma:validate:messages-service": "prisma validate --config apps/messages-service/prisma/prisma.config.ts",
    "prisma:validate:services": "npm run prisma:validate:auth-service && npm run prisma:validate:users-service && npm run prisma:validate:subscriptions-service && npm run prisma:validate:interactions-service && npm run prisma:validate:matches-service && npm run prisma:validate:messages-service",
    "prisma:migrate": "prisma migrate dev --config prisma.config.ts",
    "prisma:migrate:auth-service": "prisma migrate dev --config apps/auth-service/prisma/prisma.config.ts",
    "prisma:migrate:users-service": "prisma migrate dev --config apps/users-service/prisma/prisma.config.ts",
    "prisma:migrate:subscriptions-service": "prisma migrate dev --config apps/subscriptions-service/prisma/prisma.config.ts",
    "prisma:migrate:interactions-service": "prisma migrate dev --config apps/interactions-service/prisma/prisma.config.ts",
    "prisma:migrate:matches-service": "prisma migrate dev --config apps/matches-service/prisma/prisma.config.ts",
    "prisma:migrate:messages-service": "prisma migrate dev --config apps/messages-service/prisma/prisma.config.ts",
    "prisma:deploy": "prisma migrate deploy --config prisma.config.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/microservices": "^11.1.6",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@types/passport-jwt": "^4.0.1",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.4.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prisma": "^7.6.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
