{
  "name": "tinder",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "build:microservices": "tsc -p tsconfig.build.json",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "prisma:generate:auth": "prisma generate --config prisma/services/auth/prisma.config.ts",
    "prisma:generate:users": "prisma generate --config prisma/services/users/prisma.config.ts",
    "prisma:generate:subscriptions": "prisma generate --config prisma/services/subscriptions/prisma.config.ts",
    "prisma:generate:interactions": "prisma generate --config prisma/services/interactions/prisma.config.ts",
    "prisma:generate:matches": "prisma generate --config prisma/services/matches/prisma.config.ts",
    "prisma:generate:messages": "prisma generate --config prisma/services/messages/prisma.config.ts",
    "prisma:generate:microservices": "npm run prisma:generate:auth && npm run prisma:generate:users && npm run prisma:generate:subscriptions && npm run prisma:generate:interactions && npm run prisma:generate:matches && npm run prisma:generate:messages",
    "prisma:validate:auth": "prisma validate --config prisma/services/auth/prisma.config.ts",
    "prisma:validate:users": "prisma validate --config prisma/services/users/prisma.config.ts",
    "prisma:validate:subscriptions": "prisma validate --config prisma/services/subscriptions/prisma.config.ts",
    "prisma:validate:interactions": "prisma validate --config prisma/services/interactions/prisma.config.ts",
    "prisma:validate:matches": "prisma validate --config prisma/services/matches/prisma.config.ts",
    "prisma:validate:messages": "prisma validate --config prisma/services/messages/prisma.config.ts",
    "prisma:validate:microservices": "npm run prisma:validate:auth && npm run prisma:validate:users && npm run prisma:validate:subscriptions && npm run prisma:validate:interactions && npm run prisma:validate:matches && npm run prisma:validate:messages",
    "prisma:migrate:auth": "prisma migrate dev --config prisma/services/auth/prisma.config.ts",
    "prisma:migrate:users": "prisma migrate dev --config prisma/services/users/prisma.config.ts",
    "prisma:migrate:subscriptions": "prisma migrate dev --config prisma/services/subscriptions/prisma.config.ts",
    "prisma:migrate:interactions": "prisma migrate dev --config prisma/services/interactions/prisma.config.ts",
    "prisma:migrate:matches": "prisma migrate dev --config prisma/services/matches/prisma.config.ts",
    "prisma:migrate:messages": "prisma migrate dev --config prisma/services/messages/prisma.config.ts",
    "prisma:deploy:auth": "prisma migrate deploy --config prisma/services/auth/prisma.config.ts",
    "prisma:deploy:users": "prisma migrate deploy --config prisma/services/users/prisma.config.ts",
    "prisma:deploy:subscriptions": "prisma migrate deploy --config prisma/services/subscriptions/prisma.config.ts",
    "prisma:deploy:interactions": "prisma migrate deploy --config prisma/services/interactions/prisma.config.ts",
    "prisma:deploy:matches": "prisma migrate deploy --config prisma/services/matches/prisma.config.ts",
    "prisma:deploy:messages": "prisma migrate deploy --config prisma/services/messages/prisma.config.ts",
    "start:auth-service": "npm run build:microservices && node dist/apps/auth-service/src/main.js",
    "start:users-service": "npm run build:microservices && node dist/apps/users-service/src/main.js",
    "start:subscriptions-service": "npm run build:microservices && node dist/apps/subscriptions-service/src/main.js",
    "start:interactions-service": "npm run build:microservices && node dist/apps/interactions-service/src/main.js",
    "start:matches-service": "npm run build:microservices && node dist/apps/matches-service/src/main.js",
    "start:messages-service": "npm run build:microservices && node dist/apps/messages-service/src/main.js"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@types/passport-jwt": "^4.0.1",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.4.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prisma": "^7.6.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
