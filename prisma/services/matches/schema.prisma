generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
}

enum MatchStatus {
  ACTIVE
  UNMATCHED
  BLOCKED
}

model MatchUserSnapshot {
  userId          Int      @id @map("user_id")
  displayName     String   @map("display_name") @db.VarChar(120)
  primaryPhotoUrl String?  @map("primary_photo_url") @db.VarChar(500)
  location        String?  @db.VarChar(150)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("match_user_snapshots")
}

model Match {
  id                    Int         @id @default(autoincrement())
  userAId               Int         @map("user_a_id")
  userBId               Int         @map("user_b_id")
  status                MatchStatus @default(ACTIVE)
  createdByInteractionId Int?       @map("created_by_interaction_id")
  createdAt             DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  closedAt              DateTime?   @map("closed_at") @db.Timestamptz(6)

  @@unique([userAId, userBId])
  @@index([userAId, status])
  @@index([userBId, status])
  @@map("matches")
}
