generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
}

enum SubscriptionPlanCode {
  FREE
  GOLD
  PREMIUM
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  EXPIRED
}

model SubscriptionPlan {
  code              SubscriptionPlanCode @id
  name              String               @db.VarChar(80)
  description       String?
  superlikesPerDay  Int?                 @map("superlikes_per_day")
  features          Json?
  createdAt         DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  userSubscriptions UserSubscription[]

  @@map("subscription_plans")
}

model UserSubscription {
  id         Int                  @id @default(autoincrement())
  userId     Int                  @map("user_id")
  planCode   SubscriptionPlanCode @map("plan_code")
  status     SubscriptionStatus
  startedAt  DateTime             @map("started_at") @db.Timestamptz(6)
  expiresAt  DateTime?            @map("expires_at") @db.Timestamptz(6)
  canceledAt DateTime?            @map("canceled_at") @db.Timestamptz(6)
  createdAt  DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  plan       SubscriptionPlan     @relation(fields: [planCode], references: [code])

  @@index([userId, status])
  @@index([userId, startedAt])
  @@map("user_subscriptions")
}
