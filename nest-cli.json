{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "monorepo": true,
  "root": "apps/api-gateway",
  "sourceRoot": "apps/api-gateway/src",
  "compilerOptions": {
    "deleteOutDir": true
  },
  "projects": {
    "monolith": {
      "type": "application",
      "root": ".",
      "entryFile": "main",
      "sourceRoot": "src",
      "compilerOptions": {
        "tsConfigPath": "tsconfig.build.json"
      }
    },
    "api-gateway": {
      "type": "application",
      "root": "apps/api-gateway",
      "entryFile": "main",
      "sourceRoot": "apps/api-gateway/src",
      "compilerOptions": {
        "tsConfigPath": "apps/api-gateway/tsconfig.app.json"
      }
    },
    "auth-service": {
      "type": "application",
      "root": "apps/auth-service",
      "entryFile": "main",
      "sourceRoot": "apps/auth-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/auth-service/tsconfig.app.json"
      }
    },
    "users-service": {
      "type": "application",
      "root": "apps/users-service",
      "entryFile": "main",
      "sourceRoot": "apps/users-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/users-service/tsconfig.app.json"
      }
    },
    "subscriptions-service": {
      "type": "application",
      "root": "apps/subscriptions-service",
      "entryFile": "main",
      "sourceRoot": "apps/subscriptions-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/subscriptions-service/tsconfig.app.json"
      }
    },
    "interactions-service": {
      "type": "application",
      "root": "apps/interactions-service",
      "entryFile": "main",
      "sourceRoot": "apps/interactions-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/interactions-service/tsconfig.app.json"
      }
    },
    "matches-service": {
      "type": "application",
      "root": "apps/matches-service",
      "entryFile": "main",
      "sourceRoot": "apps/matches-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/matches-service/tsconfig.app.json"
      }
    },
    "messages-service": {
      "type": "application",
      "root": "apps/messages-service",
      "entryFile": "main",
      "sourceRoot": "apps/messages-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/messages-service/tsconfig.app.json"
      }
    }
  }
}
